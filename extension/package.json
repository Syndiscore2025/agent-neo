{
  "name": "agent-neo-vscode",
  "displayName": "Agent NEO",
  "description": "Interactive coding partner powered by Agent NEO",
  "version": "2.3.2",
  "publisher": "agent-neo",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages",
    "Machine Learning",
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "agent-neo.openChat",
        "title": "Agent NEO: Open Chat"
      },
      {
        "command": "agent-neo.explainSelection",
        "title": "Agent NEO: Explain Selection"
      },
      {
        "command": "agent-neo.refactorSelection",
        "title": "Agent NEO: Refactor Selection"
      },
      {
        "command": "agent-neo.generateTests",
        "title": "Agent NEO: Generate Tests"
      },
      {
        "command": "agent-neo.fixSelection",
        "title": "Agent NEO: Fix Selection"
      },
      {
        "command": "agent-neo.askAboutFile",
        "title": "Agent NEO: Ask About Current File"
      },
      {
        "command": "agent-neo.openTerminal",
        "title": "Agent NEO: Open Agent NEO Terminal"
      },
      {
        "command": "agent-neo.manageRepos",
        "title": "Agent NEO: Manage Repos"
      },
      {
        "command": "agent-neo.setGitHubToken",
        "title": "Agent NEO: Set GitHub Token"
      },
      {
        "command": "agent-neo.clearGitHubToken",
        "title": "Agent NEO: Clear GitHub Token"
      },
      {
        "command": "agent-neo.manageMcpServers",
        "title": "Agent NEO: Manage MCP Servers"
      },
      {
        "command": "agent-neo.manageCliTools",
        "title": "Agent NEO: Manage CLI Tools"
      },
      {
        "command": "agent-neo.toggleBackend",
        "title": "Agent NEO: Toggle Agent Backend (Neo / Auggie)"
      },
      {
        "command": "agent-neo.stopAuggie",
        "title": "Agent NEO: Stop Auggie Session"
      },
      {
        "command": "agent-neo.sendToTerminalAgent",
        "title": "Agent NEO: Send to Terminal Agent"
      },
      {
        "command": "agent-neo.stopTerminalAgent",
        "title": "Agent NEO: Stop Terminal Agent Run"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "agent-neo",
          "title": "Agent NEO",
          "icon": "media/neo.svg"
        }
      ]
    },
    "views": {
      "agent-neo": [
        {
          "type": "webview",
          "id": "agent-neo.chatView",
          "name": "Agent NEO"
        }
      ]
    },
    "menus": {
      "editor/context": [
        {
          "command": "agent-neo.explainSelection",
          "when": "editorHasSelection",
          "group": "agent-neo@1"
        },
        {
          "command": "agent-neo.refactorSelection",
          "when": "editorHasSelection",
          "group": "agent-neo@2"
        },
        {
          "command": "agent-neo.generateTests",
          "when": "editorHasSelection",
          "group": "agent-neo@3"
        },
        {
          "command": "agent-neo.fixSelection",
          "when": "editorHasSelection",
          "group": "agent-neo@4"
        }
      ]
    },
    "configuration": {
      "title": "Agent NEO",
      "properties": {
        "agentNeo.apiUrl": {
          "type": "string",
          "default": "http://127.0.0.1:8000",
          "description": "Agent NEO API URL"
        },
        "agentNeo.apiToken": {
          "type": "string",
          "default": "",
          "description": "Agent NEO API Bearer Token"
        },
        "agentNeo.enableInlineCompletion": {
          "type": "boolean",
          "default": true,
          "description": "Enable inline code completion"
        },
        "agentNeo.enableSuggestions": {
          "type": "boolean",
          "default": true,
          "description": "Enable prompt suggestions"
        },
        "agentNeo.agentBackend": {
          "type": "string",
          "enum": [
            "neo",
            "auggie"
          ],
          "enumDescriptions": [
            "Use the Agent NEO backend (HTTP API at agentNeo.apiUrl)",
            "Use the Auggie CLI as a local subprocess (requires 'auggie' installed and 'auggie login')"
          ],
          "default": "neo",
          "description": "Which agent runs your prompts: the Neo backend or the local Auggie CLI."
        },
        "agentNeo.auggiePath": {
          "type": "string",
          "default": "auggie",
          "description": "Path or command used to launch the Auggie CLI (defaults to 'auggie' on PATH)."
        },
        "agentNeo.terminalAgent.enabled": {
          "type": "boolean",
          "default": false,
          "description": "Enable the Terminal Agent Orchestrator. When off, Neo behaves exactly as before."
        },
        "agentNeo.terminalAgent.defaultProvider": {
          "type": "string",
          "default": "augment-cli",
          "description": "Default terminal-agent provider id. Augment CLI ships first; more providers register at runtime."
        },
        "agentNeo.terminalAgent.cliPath": {
          "type": "string",
          "default": "auggie",
          "description": "Path or command used to launch the selected CLI agent (e.g. 'auggie', or a full path)."
        },
        "agentNeo.terminalAgent.defaultWorkingDir": {
          "type": "string",
          "default": "",
          "description": "Default working directory / repo path for runs. Empty uses the first workspace folder."
        },
        "agentNeo.terminalAgent.promptTemplate": {
          "type": "string",
          "editPresentation": "multilineText",
          "default": "",
          "description": "Prompt template with {{variables}} (repo_path, current_branch, user_request, …). Empty uses the built-in default."
        },
        "agentNeo.terminalAgent.maxTimeoutSeconds": {
          "type": "number",
          "default": 1800,
          "description": "Hard timeout for a run, in seconds. Set 0 to disable the timeout."
        },
        "agentNeo.terminalAgent.captureOutput": {
          "type": "boolean",
          "default": true,
          "description": "Capture stdout/stderr from Neo-launched runs into the rolling buffer."
        },
        "agentNeo.terminalAgent.autoSaveSummaries": {
          "type": "boolean",
          "default": true,
          "description": "Automatically save a (secret-redacted) run summary to history when a run ends."
        },
        "agentNeo.terminalAgent.observer.enabled": {
          "type": "boolean",
          "default": false,
          "description": "Enable Terminal Observer. Only active when the Terminal Agent Orchestrator is enabled."
        },
        "agentNeo.terminalAgent.observer.mode": {
          "type": "string",
          "enum": [
            "neo-process",
            "vscode-terminal",
            "log-file",
            "manual"
          ],
          "enumDescriptions": [
            "Observe a process Neo launched (full stdout/stderr capture)",
            "Best-effort read of the VS Code integrated terminal (limited by API)",
            "Tail a terminal log file the CLI is configured to write",
            "Manually paste / import the latest CLI output"
          ],
          "default": "neo-process",
          "description": "How the Terminal Observer obtains CLI output."
        },
        "agentNeo.terminalAgent.observer.logFilePath": {
          "type": "string",
          "default": "",
          "description": "Path to a terminal log file to tail (used when observer.mode is 'log-file')."
        },
        "agentNeo.terminalAgent.confirmBeforeSendingInput": {
          "type": "boolean",
          "default": true,
          "description": "Require explicit confirmation before Neo sends any input to a terminal session."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.0.0",
    "typescript": "^5.3.0",
    "vitest": "^2.1.9"
  },
  "dependencies": {
    "@vscode/webview-ui-toolkit": "^1.4.0",
    "axios": "^1.6.0",
    "marked": "^11.0.0"
  }
}
