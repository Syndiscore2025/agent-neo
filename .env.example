# AGENT NEO Configuration

# Repository path to manage (REQUIRED)
REPO_PATH=/path/to/your/repository

# Authentication (REQUIRED for production)
# Generate with: python -c "from app.core.auth import generate_secure_token; print(generate_secure_token())"
AGENT_NEO_TOKEN=your-secure-token-here

# Server configuration
HOST=127.0.0.1
PORT=8000

# Test command (optional - auto-detected if not set)
# TEST_COMMAND=pytest --tb=short -v

# Logging level
LOG_LEVEL=INFO

# Optional: Skip push (for testing)
# SKIP_PUSH=false

# Optional: Require remote reachability check
# REQUIRE_REMOTE=true

