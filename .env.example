# AGENT NEO Configuration

# Repository path to manage (REQUIRED)
REPO_PATH=/path/to/your/repository

# Authentication (REQUIRED for production)
# Generate with: python -c "from app.core.auth import generate_secure_token; print(generate_secure_token())"
AGENT_NEO_TOKEN=your-secure-token-here

# Server configuration
HOST=127.0.0.1
PORT=8000

# Test command (optional - auto-detected if not set)
# TEST_COMMAND=pytest --tb=short -v

# Logging level
LOG_LEVEL=INFO

# Optional: Skip push (for testing)
# SKIP_PUSH=false

# Optional: Require remote reachability check
# REQUIRE_REMOTE=true

# Enterprise: Coverage enforcement (default: true)
# ENFORCE_COVERAGE=true

# ============================================
# GitHub Auto-Discovery Calibration (v2.1)
# ============================================

# GitHub API token (fine-grained, read-only repo access)
# Required for /calibrate/discover endpoint
# GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# GitHub owner (username or organization name)
# GITHUB_OWNER=your-username-or-org

# GitHub account type: personal or org
# GITHUB_TYPE=personal

# Calibration cache directory for shallow clones
CALIBRATION_CACHE_DIR=/opt/agent-neo/calibration

# Topic filters for repo discovery (comma-separated)
# Include only repos with these topics (empty = include all)
# CALIBRATION_INCLUDE_TOPICS=production

# Exclude repos with these topics
CALIBRATION_EXCLUDE_TOPICS=prototype,experimental,sandbox,archive

# Maximum repos to analyze per calibration run
CALIBRATION_MAX_REPOS=50
