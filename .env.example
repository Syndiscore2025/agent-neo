# AGENT NEO Configuration

# Repository path to manage (REQUIRED)
REPO_PATH=/path/to/your/repository

# Authentication (REQUIRED for production)
# Generate with: python -c "from app.core.auth import generate_secure_token; print(generate_secure_token())"
AGENT_NEO_TOKEN=your-secure-token-here

# Server configuration
HOST=127.0.0.1
PORT=8000

# Test command (optional - auto-detected if not set)
# TEST_COMMAND=pytest --tb=short -v

# Logging level
LOG_LEVEL=INFO

# Optional: Skip push (for testing)
# SKIP_PUSH=false

# Optional: Require remote reachability check
# REQUIRE_REMOTE=true

# Enterprise: Coverage enforcement (default: true)
# ENFORCE_COVERAGE=true

# ============================================
# GitHub Auto-Discovery Calibration (v2.1)
# ============================================

# GitHub API token (fine-grained, read-only repo access)
# Required for /calibrate/discover endpoint
# GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# GitHub owner (username or organization name)
# GITHUB_OWNER=your-username-or-org

# GitHub account type: personal or org
# GITHUB_TYPE=personal

# Calibration cache directory for shallow clones
CALIBRATION_CACHE_DIR=/opt/agent-neo/calibration

# Topic filters for repo discovery (comma-separated)
# Include only repos with these topics (empty = include all)
# CALIBRATION_INCLUDE_TOPICS=production

# Exclude repos with these topics
CALIBRATION_EXCLUDE_TOPICS=prototype,experimental,sandbox,archive

# Maximum repos to analyze per calibration run
CALIBRATION_MAX_REPOS=50

# ============================================
# Interactive Layer Configuration (v2.1+)
# ============================================

# LLM API Keys (REQUIRED for interactive features)
# Get from: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx

# Get from: https://platform.openai.com/
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxx

# Default model when a request doesn't pick one. Accepts a catalog alias
# (claude-sonnet, claude-opus, gpt, gpt-4o, o1, o3) or any raw model id —
# claude* routes to Anthropic; gpt*/o1*/o3*/o4*/chatgpt* route to OpenAI.
DEFAULT_MODEL=claude-sonnet

# Model the "gpt" alias resolves to (any OpenAI model id)
# OPENAI_MODEL=o1

# Extra models to add to the picker catalog (comma-separated raw model ids)
# NEO_ANTHROPIC_MODELS=claude-haiku-4-20250514
# NEO_OPENAI_MODELS=gpt-4o-mini,o3-mini

# How often (hours) to refresh model lists + token prices in the background
# (24 = daily, 168 = weekly, 0 = disable). Force with POST /models/refresh.
# NEO_MODEL_REFRESH_HOURS=24

# Where the model/pricing cache file is written (default ~/.agent-neo/)
# NEO_PRICING_CACHE=/tmp/agent-neo-model-pricing.json

# Session configuration
MAX_SESSION_HISTORY=100
SESSION_TIMEOUT_MINUTES=60

# Attachment configuration
MAX_ATTACHMENT_SIZE_MB=10
ATTACHMENT_TEMP_DIR=/tmp/agent-neo-attachments

# Completion configuration
COMPLETION_TIMEOUT_SECONDS=5
COMPLETION_MAX_TOKENS=500
